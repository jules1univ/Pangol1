@startuml
title visustats

skinparam classAttributeIconSize 0

abstract class AbstractDataGroupView {
  # data : DataGroup
  # spacing : double
  # center : Point
  --
  # {abstract} getTotalElementsHeight() : double
  # getTotalElementsWidth() : double
  # {abstract} isAxisEnabled() : boolean
  # {abstract} getAxisElement() : IShape
  # {abstract} getElementWidth() : double
  # {abstract} createElement(Point position) : IDataSetView
  - getElementCenterAt(int index) : Point
  # update() : void
  + setTitle(Label title) : void
  + setData(DataGroup group) : void
  + addData(DataSet data) : void
